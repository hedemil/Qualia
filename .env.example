# HuggingFace token (required for uploading datasets)
# Get yours at: https://huggingface.co/settings/tokens (needs write access)
HF_TOKEN=hf_your_token_here

# Anthropic API key (required for instruction variation augmentation)
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your_key_here
